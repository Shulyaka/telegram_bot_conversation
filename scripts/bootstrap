#!/bin/sh

# script/bootstrap: Install/update all dependencies required to run the project

set -e

cd "$(dirname "$0")/.."

echo "==> Checking for uv..."
if ! command -v uv >/dev/null 2>&1; then
  echo "UV not found, installing..."
  if ! command -v pipx >/dev/null 2>&1; then
    python3 -m pip install uv
  else
    pipx install uv
  fi
fi

if [ -z "$HA_VERSION" ] || [ "$HA_VERSION" = "hacs" ]; then
  HA_VERSION=$(grep '"homeassistant"' hacs.json | head -1 | sed 's/.*"homeassistant"\s*:\s*"\([^"]*\)".*/\1/')
fi

if [ -z "$HA_VERSION" ] || [ "$HA_VERSION" = "latest" ]; then
  HA_VERSION=$(curl -fsSL https://pypi.org/pypi/homeassistant/json | sed -n 's/.*"version": *"\([^"]*\)".*/\1/p' | head -1)
fi

if [ -z "$HA_VERSION" ]; then
  echo "Error: Could not determine Home Assistant version. Please set the HA_VERSION environment variable."
  exit 1
fi

echo "==> Installing dependencies..."

PIPARGS="--upgrade"
if [ -z "$VIRTUAL_ENV" ]; then
  echo "No virtual environment detected, installing globally..."
  PIPARGS="$PIPARGS --system"
else
  echo "Virtual environment detected: $VIRTUAL_ENV"
fi

tmpdir=$(mktemp -d)
trap "rm -rf $tmpdir" EXIT

if [ "$1" = "--full" ]; then
  echo "Fetching Home Assistant dependencies for version ${HA_VERSION}..."

  HA_CORE_BASE_URL="https://raw.githubusercontent.com/home-assistant/core/${HA_VERSION}"
  mkdir -p $tmpdir/homeassistant
  curl -fsSL "${HA_CORE_BASE_URL}/homeassistant/package_constraints.txt" -o $tmpdir/homeassistant/package_constraints.txt  # constraints for requirements files
  curl -fsSL "${HA_CORE_BASE_URL}/requirements.txt" -o $tmpdir/requirements.txt  # required by requirements_all.txt
  curl -fsSL "${HA_CORE_BASE_URL}/requirements_test_pre_commit.txt" -o $tmpdir/requirements_test_pre_commit.txt  # required by requirements_test.txt
  curl -fsSL "${HA_CORE_BASE_URL}/requirements_test.txt" -o $tmpdir/requirements_test.txt  # required by requirements_test_all.txt
  curl -fsSL "${HA_CORE_BASE_URL}/requirements_test_all.txt" -o $tmpdir/requirements_test_all.txt

  PIPARGS="$PIPARGS --requirement $tmpdir/requirements_test_all.txt"
fi

case "$HA_VERSION" in
    # prerelease: contains a/b/rc suffix
    *[0-9]a[0-9]*|*[0-9]b[0-9]*|*[0-9]rc[0-9]*)
        PIPARGS="$PIPARGS --pre"
        HA_INSTALL_ARG="homeassistant==${HA_VERSION}"
        ;;
    # git ref: contains characters other than digits and dots
    *[!0-9.]*)
        HA_INSTALL_ARG="git+https://github.com/home-assistant/core.git@${HA_VERSION}"
        ;;
    # release: digits and dots only
    *)
        HA_INSTALL_ARG="homeassistant==${HA_VERSION}"
        ;;
esac

if [ "$1" != "--full" ]; then
  PHACC_VERSION=$( (uv pip install --dry-run $PIPARGS --requirement requirements.txt $HA_INSTALL_ARG || uv pip install $PIPARGS --requirement requirements.txt ) 2>&1 | grep "+ pytest-homeassistant-custom-component" | sed -e 's/.*==//')
  if [ -z "$PHACC_VERSION" ]; then
    PHACC_VERSION=$(uv pip show pytest-homeassistant-custom-component | grep ^Version: | awk '{print $2}')
  fi
  if [ -z "$PHACC_VERSION" ]; then
    echo "Error: Could not determine pytest-homeassistant-custom-component version."
    exit 1
  fi
  echo "Fetching pytest-homeassistant-custom-component dependencies for version ${PHACC_VERSION}..."
  PHACC_BASE_URL="https://raw.githubusercontent.com/MatthewFlamm/pytest-homeassistant-custom-component/${PHACC_VERSION}"
  curl -fsSL "${PHACC_BASE_URL}/requirements_dev.txt" -o $tmpdir/requirements_dev.txt
  PIPARGS="$PIPARGS --requirement $tmpdir/requirements_dev.txt"
fi

uv pip install $PIPARGS --requirement requirements.txt $HA_INSTALL_ARG || {
  echo "Warning: Failed to install dependencies. This usually means that the requirements in requirements.txt are incompatible with the specified Home Assistant version (${HA_VERSION}). Trying again with installing requirements.txt and Home Assistant separately. This may lead to incompatible dependencies, but should work in most cases."
  uv pip install $PIPARGS --requirement requirements.txt
  uv pip install $PIPARGS $HA_INSTALL_ARG
}

echo "==> Installing prek hooks..."
pre-commit uninstall
prek install

echo "==> Bootstrap completed!"
